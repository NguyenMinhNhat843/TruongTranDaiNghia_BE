// Đây là file cấu hình chính của Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Bạn có thể đổi thành "mysql" hoặc "sqlite" tùy nhu cầu
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  username  String   @unique
  password  String
  email     String?  @unique
  role      UserRole @default(STAFF) // Phân cấp Role chính
  fullName     String @default("Unknow")
  gender       String @default("Unknow")
  phone        String?
  birthday     DateTime?
  address      String?
  isActive  Boolean  @default(true)
  
  // Quan hệ 1:1 với Profile nghiệp vụ
  staff     Staff?
  student   Student?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  STAFF
  TEACHER
  STUDENT
}

// --- PHÂN HỆ NHÂN SỰ ---
model Staff {
  id           String     @id
  staffCode    String     @unique // Mã nhân viên (VD: NV001)
  
  // Liên kết hệ thống
  user         User       @relation(fields: [userId], references: [id])
  userId       String     @unique
  
  // Liên kết tổ chức
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String

  position     String?    // Chức vụ: Trưởng khoa, Giảng viên...
  isTeaching   Boolean    @default(true) // Có tham gia giảng dạy không

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// --- PHÂN HỆ HỌC SINH ---
model Student {
  id           String        @id
  studentCode  String        @unique // Mã số học sinh (VD: HS2024001)
  citizenId    String?       @unique // Số CCCD
  
  // Thông tin nhập học
  enrollmentDate DateTime    @default(now())
  status       StudentStatus @default(STUDYING)

  // Liên kết hệ thống (Có thể null nếu học sinh chưa được cấp account)
  user         User?         @relation(fields: [userId], references: [id])
  userId       String?       @unique

  // Liên kết học thuật
  major        Major         @relation(fields: [majorId], references: [id]) // Ngành nghề
  majorId      String
  class        Class?        @relation(fields: [classId], references: [id]) // Lớp hoc
  classId      String?

  // Quan hệ khác
  grades       Grade[]      // Điểm số
  gradResults  GraduationResult[]   // Kết quả thi

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum StudentStatus {
  STUDYING    // Đang học
  DROPPED     // Thôi học
  SUSPENDED   // Bảo lưu
  GRADUATED   // Đã tốt nghiệp
}

// 1. Thêm Model Department
// Phòng ban / Khoa
model Department {
  id        String   @id
  code      String   @unique
  name      String   @unique
  staffs    Staff[]
  majors    Major[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Thêm Model Major - Ngành học / chuyên ngành
model Major {
  id           String     @id
  code         String     @unique
  name         String
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  students     Student[]
  classes      Class[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// 3. Thêm Model Class - Lớp học
model Class {
  id        String    @id
  name      String    @unique // VD: CNTT-K24A
  major     Major     @relation(fields: [majorId], references: [id])
  majorId   String
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 4. Thêm Model Grade (Tạm thời để đơn giản để chạy được migrate)
model Grade {
  id        String  @id
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  score     Float?
  subject   String // Sau này mình tách Subject sau
}

// 5. Thêm Model GraduationResult
model GraduationResult {
  id        String  @id
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  status    String  // PASSED, FAILED...
}

// ========================= Hồ sơ tuyển sinh ===========================
